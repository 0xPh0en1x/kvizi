# Telegram Bot API token from BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace-me

# Forum supergroup id, usually starts with -100.
TELEGRAM_CHAT_ID=-1001234567890

# Long random string used in /telegram/<secret> and
# X-Telegram-Bot-Api-Secret-Token.
KVIZI_WEBHOOK_SECRET=replace-with-long-random-webhook-secret

# Long random string used by cron-job.org in X-Kvizi-Cron-Secret.
KVIZI_CRON_SECRET=replace-with-long-random-cron-secret

# Telegram numeric user ids allowed to run /kvizi_* admin commands.
KVIZI_ADMIN_IDS=111111111,222222222

# Optional runtime settings.
KVIZI_TZ=Europe/Moscow
KVIZI_OPEN_SECONDS=7200
KVIZI_DB_PATH=data/kvizi.sqlite3
KVIZI_QUESTIONS_PATH=questions.csv
KVIZI_SEASON=main
KVIZI_ANNOUNCE_THREAD_ID=
KVIZI_CHAT_USERNAME=
KVIZI_ANNOUNCE_FIRST_ANSWER=true
KVIZI_ANNOUNCE_NO_ANSWERS=true
KVIZI_ANNOUNCE_RISK_FAILURES=true
KVIZI_ANNOUNCE_STREAKS=true

# Optional scoring balance. Unknown difficulties fall back to normal values
# unless listed here.
KVIZI_DIFFICULTY_POINTS=easy:5,normal:10,hard:15,ccna:20
KVIZI_CHALLENGE_REWARDS=easy:5:10,normal:10:25,hard:15:40,ccna:20:55

# Optional helper for scripts/set_webhook.py.
KVIZI_PUBLIC_BASE_URL=https://YOUR_USERNAME.pythonanywhere.com
